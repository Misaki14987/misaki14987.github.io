---
import BaseLayout from './BaseLayout.astro';
import '../styles/layouts/markdown-layout.scss';

const { frontmatter, canonical, seoDescription } = Astro.props;
const {
    title,
    description,
    pubDate,
    author = 'M1saK1',
    tags = [],
    category,
    cover,
} = frontmatter;
const pageDescription = seoDescription ?? description;

const formatPostDate = (date: Date) => {
    const parts = new Intl.DateTimeFormat('zh-CN', {
        timeZone: 'Asia/Shanghai',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
    }).formatToParts(date);
    const values = Object.fromEntries(parts.map(({ type, value }) => [type, value]));
    return {
        display: `${values.year}年${values.month}月${values.day}日`,
        machine: `${values.year}-${values.month}-${values.day}`,
    };
};

const formattedDate = pubDate ? formatPostDate(new Date(pubDate)) : undefined;
---

<BaseLayout
    title={`${title} | M1saK1 Blog`}
    description={pageDescription}
    canonical={canonical}
    ogType='article'
    ogImage={cover?.src}
    ogImageAlt={title}
    publishedTime={pubDate}
    tags={tags}
    bodyClass='bg-transparent'
>
    <section class='post-section'>
        <article class='post-article'>
            <header class='post-header'>
                {category && <p class='post-header__category'>{category}</p>}
                <h1 class='post-header__title'>{title}</h1>
                {description && <p class='post-header__description'>{description}</p>}
                <div class='post-header__meta'>
                    {author && <span>{author}</span>}
                    {formattedDate && <time datetime={formattedDate.machine}>{formattedDate.display}</time>}
                </div>
                {tags.length > 0 && (
                    <ul class='post-header__tags'>
                        {tags.map((tag:string) => (
                            <li class='post-header__tag'>
                                {tag}
                            </li>
                        ))}
                    </ul>
                )}
            </header>
            <div class='article-content'>
                <slot />
            </div>
        </article>
    </section>
</BaseLayout>
