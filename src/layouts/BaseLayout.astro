---
import '../global.scss';
import '../styles/layouts/base-layout.scss';
import '../styles/themes/newspaper.scss';
import SiteHead from '../components/common/SiteHead.astro';
import ThemeController from '../components/common/ThemeController.astro';
import { SITE_TITLE } from '../scripts/seo';

const {
    title = SITE_TITLE,
    description,
    bodyClass = '',
    canonical,
    ogType = 'website',
    ogImage,
    ogImageAlt = title,
    publishedTime,
    modifiedTime,
    tags = [],
} = Astro.props;
---
<html lang='zh-CN' data-theme='units'>
  <head>
    <script is:inline>
      try {
        const requestedTheme = new URLSearchParams(location.search).get('theme');
        const savedTheme = localStorage.getItem('site-theme');
        const normalizeTheme = (value) => value === 'newspaper' || value === 'plain' ? 'newspaper' : 'units';
        document.documentElement.dataset.theme = ['units', 'newspaper', 'plain'].includes(requestedTheme)
          ? normalizeTheme(requestedTheme)
          : normalizeTheme(savedTheme);
      } catch {}
    </script>
    <SiteHead
      title={title}
      description={description}
      canonical={canonical}
      ogType={ogType}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
    />
    <slot name='head' />
  </head>

  <body class={`body ${bodyClass}`}>
    <ThemeController />
    <main class='main'>
      <slot />
    </main>

    <script>
      import { initializeSiteRuntime } from "../scripts/client/site-runtime";

      initializeSiteRuntime();
    </script>
  </body>
</html>
