---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import UnitsShell from '../components/common/UnitsShell.astro';
import NewspaperHome from '../components/themes/newspaper/NewspaperHome.astro';
import FriendLink from '../components/FriendLink.astro';
import { formatPostDate, getAllTags, getPostCards, getPublishedPosts } from '../scripts/publication';
import '../styles/pages/index.scss';

const posts = await getPublishedPosts();
const articles = getPostCards(posts.filter((post) => post.data.kind === 'article'));
const diaries = getPostCards(posts.filter((post) => post.data.kind === 'diary'));
const featured = articles[0];
const tags = getAllTags(posts.filter((post) => post.data.kind === 'article')).slice(0, 10);
const featuredDate = featured?.pubDate ? formatPostDate(featured.pubDate) : null;
const archives = [
  { id: 'articles', number: '02', label: 'PROOF', zh: '一些分享', en: 'Articles', tone: 'yellow', posts: articles, fallback: 'ARTICLE' },
  { id: 'diary', number: '03', label: 'PRIVATE PRESS', zh: '胡思乱想', en: 'Diary', tone: 'orange', posts: diaries, fallback: 'DIARY' },
];
const profileStats = [
  ['base', 'Hangzhou / HDU'],
  ['practice', 'Frontend systems', 'Agent'],
  ['outside', 'Rhythm game / TCG ']
];
const interests = ['Coding', 'Rhythm Game', 'TCG', 'Idol'];
---

<BaseLayout
  title="M1saK1 Blog"
  description="M1saK1 的个人博客首页"
  ogImage="/images/vn-blog-hero.png"
  bodyClass="units-body"
>
  <UnitsShell active="home">
    <div class="units-home" data-home-motion data-theme-content="units">
      {featured && (
        <section class="units-hero" id="latest" data-home-hero>
          <a class="units-hero__media" href={featured.link} aria-label={`阅读 ${featured.title}`}>
            {featured.image ? (
              typeof featured.image === 'string' ? (
                <img src={featured.image} alt="" loading="eager" decoding="async" />
              ) : (
                <Image
                  src={featured.image}
                  alt=""
                  widths={[720, 1040, 1440]}
                  sizes="(max-width: 920px) calc(100vw - 20px), calc(100vw - 188px)"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              )
            ) : (
              <div class="units-hero__fallback" aria-hidden="true"></div>
            )}
          </a>

          <div class="units-hero__registration">
            <div class="units-hero__plates" aria-hidden="true">
              <span>DESIGN</span>
              <span>CODE</span>
              <span>PLAY</span>
            </div>
            <h1>
              <button type="button" data-author-mark aria-label="M1saK1，连续点击三次查看印刷批次">
                <span class="units-author units-author--blue" aria-hidden="true">M1saK1</span>
                <span class="units-author units-author--orange" aria-hidden="true">M1saK1</span>
                <span class="units-author units-author--yellow" aria-hidden="true">M1saK1</span>
                <span class="units-author units-author--key">M1saK1</span>
              </button>
            </h1>
          </div>

          <div class="units-batch-stamp" data-batch-stamp aria-hidden="true">
            <span>LOT 14987</span>
            <strong>ZERO SUGAR</strong>
          </div>

          <div class="units-hero__copy">
            <p>01 / LATEST · {featuredDate?.display ?? 'NOW'}</p>
            <h2>{featured.title}</h2>
            <span>{featured.description}</span>
            <a href={featured.link}>Read the note <i aria-hidden="true">↗</i></a>
          </div>
        </section>
      )}

      {archives.map((archive) => (
        <section class={`units-panel units-panel--${archive.tone}`} id={archive.id} data-print-section>
          <header class="units-panel__head">
            <div>
              <span>{archive.number} / {archive.label}</span>
              <h2 data-i18n data-zh={archive.zh} data-en={archive.en}>{archive.zh}</h2>
            </div>
            {archive.id === 'articles' && (
              <a href="#subjects" data-i18n data-zh="主题索引 ↗" data-en="Subjects ↗">主题索引 ↗</a>
            )}
          </header>

          <div class="units-posts">
            {archive.posts.map((blog, index) => (
              <a class={`units-post units-post--${index % 4}`} href={blog.link}>
                <span class="units-post__cover">
                  {blog.image ? (
                    typeof blog.image === 'string' ? (
                      <img src={blog.image} alt="" loading="lazy" decoding="async" />
                    ) : (
                      <Image
                        src={blog.image}
                        alt=""
                        widths={[320, 560, 760]}
                        sizes="(max-width: 920px) calc(100vw - 64px), 30vw"
                        loading="lazy"
                        decoding="async"
                      />
                    )
                  ) : (
                    <i aria-hidden="true"></i>
                  )}
                </span>
                <span class="units-post__copy">
                  <small>{String(index + 1).padStart(2, '0')} / {blog.subtitle || archive.fallback}</small>
                  <strong>{blog.title}</strong>
                  <p>{blog.description}</p>
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}

      <section class="units-panel units-panel--green" id="works" data-print-section>
        <header class="units-panel__head">
          <div>
            <span>04 / PORTFOLIO</span>
            <h2 data-i18n data-zh="作品集" data-en="Works">作品集</h2>
          </div>
        </header>
        <div class="units-empty">
          <strong>NO WORKS, YET.</strong>
          <p data-i18n data-zh="这里会放完成并愿意公开的项目。" data-en="Finished public projects will live here.">这里会放完成并愿意公开的项目。</p>
        </div>
      </section>

      <section class="units-panel units-panel--yellow" id="about" data-print-section>
      <header class="units-panel__head">
        <div>
          <span>05 / PLATES</span>
          <h2 data-i18n data-zh="关于我" data-en="About Me">关于我</h2>
        </div>
      </header>

      <div class="units-about">
        <div>
          <h3>M1saK1</h3>
          <p>From HDU, I LOVE Schweppes</p>
        </div>
        <dl>
          {profileStats.map(([term, value]) => (
            <>
              <dt>{term}</dt>
              <dd>{value}</dd>
            </>
          ))}
        </dl>
      </div>

      <div class="units-chips" aria-label="Interests">
        {interests.map((interest, index) => (
          <span><i>{String(index + 1).padStart(2, '0')}</i>{interest}</span>
        ))}
      </div>
      </section>

      <section class="units-panel units-panel--orange" id="subjects" data-print-section>
      <header class="units-panel__head">
        <div>
          <span>06 / TYPE CASE</span>
          <h2 data-i18n data-zh="主题索引" data-en="Subjects">主题索引</h2>
        </div>
      </header>

      <div class="units-tags">
        {tags.map((tag) => (
          <a href="#articles">
            {tag}
          </a>
        ))}
      </div>
      </section>

      <section class="units-panel units-panel--white" id="friends" data-print-section>
        <span class="units-panel__label">07 / EXCHANGE</span>
        <FriendLink />
      </section>
    </div>
    <NewspaperHome {featured} {articles} {diaries} {tags} />
  </UnitsShell>
</BaseLayout>

<script>
  import { initializeHomeMotion } from '../scripts/client/home/home-motion';

  initializeHomeMotion();
</script>
