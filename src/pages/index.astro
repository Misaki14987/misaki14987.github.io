---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import Self from '../components/Self.astro';
import blogs from '../scripts/utils';
import '../styles/pages/index.scss';
---

<BaseLayout
  title="M1saK1 Blog"
  description="M1saK1 的个人博客首页，归档 Web 开发、Rust 学习、数学笔记和日常记录。"
>
  <div class="home">
    <!-- Intro 横跨两列 -->
    <section class="home-intro page-reveal">
      <div class="home-intro__label">ARCHIVE TERMINAL / HOME</div>

      <h1>M1sak1 Personal Archive Terminal</h1>

      <p>status: learning rust / writing notes / staying online</p>

      <div class="home-intro__status">
        <span>SYS_VER 1.0.0</span>
        <span>ARCHIVE COUNT {String(blogs.length).padStart(3, '0')}</span>
        <span>SIGNAL ONLINE</span>
      </div>
    </section>

    <!-- 左侧 Identity Pass -->
    <aside class="page-reveal page-reveal--delay-1">
      <Self />
    </aside>

    <!-- 右侧 Log Stream -->
    <section class="log-stream  page-reveal page-reveal--delay-2 ">
      <header class="log-head">
        <div>
          <h2>LOG STREAM</h2>
          <span>entries from /notes</span>
        </div>
        <span>ARCHIVE COUNT: {String(blogs.length).padStart(3, '0')}</span>
      </header>

      {blogs.map((blog, i) => (
        <BlogCard
          title={blog.title}
          subtitle={blog.subtitle}
          image={blog.image}
          link={blog.link}
          description={blog.description}
          pubDate={blog.pubDate}
          tags={blog.tags}
          entryId={blog.entryId}
          priority={i === 0}
        />
      ))}
    </section>
  </div>
</BaseLayout>
