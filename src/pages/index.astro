---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import UnitsShell from '../components/common/UnitsShell.astro';
import FriendLink from '../components/FriendLink.astro';
import { formatPostDate, getAllTags, getPostCards, getPublishedPosts } from '../scripts/publication';
import '../styles/pages/index.scss';

const posts = await getPublishedPosts();
const blogs = getPostCards(posts);
const featured = blogs[0];
const tags = getAllTags(posts).slice(0, 10);
const featuredDate = featured?.pubDate ? formatPostDate(featured.pubDate) : null;
const profileStats = [
  ['base', 'Hangzhou / HDU'],
  ['practice', 'Frontend systems'],
  ['learning', 'Rust / GNOME / Math'],
  ['outside', 'Rhythm game / TCG / Idol'],
];
const interests = ['Coding', 'Rhythm Game', 'TCG', 'Idol'];
---

<BaseLayout
  title="M1saK1 Blog"
  description="M1saK1 的个人博客首页"
  ogImage="/images/vn-blog-hero.png"
  bodyClass="units-body"
>
  <UnitsShell active="home">
    {featured && (
      <section class="units-hero" id="latest">
        <a class="units-hero__media" href={featured.link} aria-label={`阅读 ${featured.title}`}>
          {featured.image ? (
            typeof featured.image === 'string' ? (
              <img src={featured.image} alt={featured.title} loading="eager" decoding="async" />
            ) : (
              <Image
                src={featured.image}
                alt={featured.title}
                widths={[720, 1040, 1440]}
                sizes="(max-width: 920px) calc(100vw - 20px), calc(100vw - 188px)"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            )
          ) : (
            <div class="units-hero__fallback" aria-hidden="true"></div>
          )}
        </a>

        <div class="units-hero__copy">
          <p>{featuredDate?.display ?? 'Latest'}</p>
          <h1>{featured.title}</h1>
          <span>{featured.description}</span>
          <a href={featured.link}>Read the note ↗</a>
        </div>
      </section>
    )}

    <section class="units-panel units-panel--yellow" id="archive">
      <header class="units-panel__head">
        <h2 data-i18n data-zh="文章归档" data-en="Archive, but louder.">文章归档</h2>
        <a href="#subjects" data-i18n data-zh="主题索引 ↗" data-en="Subjects ↗">主题索引 ↗</a>
      </header>

      <div class="units-posts">
        {blogs.map((blog, index) => {
          return (
            <a class={`units-post units-post--${index % 4}`} href={blog.link}>
              <strong>{blog.title}</strong>
              <p>{blog.description}</p>
            </a>
          );
        })}
      </div>
    </section>

    <section class="units-panel units-panel--green" id="about">
      <header class="units-panel__head">
        <h2 data-i18n data-zh="关于我" data-en="AboutMe">关于我</h2>
      </header>

      <div class="units-about">
        <div>
          <h3>M1saK1</h3>
          <p>From HDU, I LOVE Schweppes</p>
        </div>
        <dl>
          {profileStats.map(([term, value]) => (
            <>
              <dt>{term}</dt>
              <dd>{value}</dd>
            </>
          ))}
        </dl>
      </div>

      <div class="units-chips">
        {interests.map((interest) => (
          <span>{interest}</span>
        ))}
      </div>
    </section>

    <section class="units-panel units-panel--orange" id="subjects">
      <header class="units-panel__head">
        <h2 data-i18n data-zh="主题索引" data-en="Subjects">主题索引</h2>
      </header>

      <div class="units-tags">
        {tags.map((tag) => (
          <a href="#archive">
            {tag}
          </a>
        ))}
      </div>
    </section>

    <section class="units-panel units-panel--white" id="friends">
      <FriendLink />
    </section>
  </UnitsShell>
</BaseLayout>
