---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnitsShell from '../../components/common/UnitsShell.astro';
import { getAllTags, getPublishedPosts, tagPath } from '../../scripts/publication';

const tags = getAllTags(await getPublishedPosts());
---

<BaseLayout
  title="Tags | M1saK1 Blog"
  description="M1saK1 Blog 的标签索引。"
  ogImage="/images/vn-blog-hero.png"
  bodyClass="units-body"
  showNavigation={false}
>
  <UnitsShell active="subjects">
    <section class="units-panel units-panel--orange">
      <header class="units-panel__head">
        <span>{String(tags.length).padStart(2, '0')}</span>
        <h1>Subjects</h1>
        <a href="/">Home ↗</a>
      </header>

      <div class="units-tags">
        {tags.map((tag, index) => (
          <a href={tagPath(tag)}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            {tag}
          </a>
        ))}
      </div>
    </section>
  </UnitsShell>
</BaseLayout>
