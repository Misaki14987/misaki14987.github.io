---
import { getCollection } from 'astro:content';
import Card from "../../components/common/Card.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection('posts');
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
---

<BaseLayout title='Tags'>
    <div class='flex flex-row mt-4 w-1/2 mx-auto justify-center items-center flex-wrap gap-4'>
        <p class='text-lg font-extrabold'>所有标签</p>
        {tags.map((tag) => (
            <Card title={tag} class='w-fit bg-gray-500/20 hover:bg-gray-500/30 transition-colors'>
                <a href={`/tags/${tag}`} class='tag'>
                    {tag}
                </a>
            </Card>
        ))}
    </div>
</BaseLayout>
