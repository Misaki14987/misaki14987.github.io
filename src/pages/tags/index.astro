---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags, getPublishedPosts, tagPath } from '../../scripts/publication';
import '../../styles/pages/tags.scss';

const tags = getAllTags(await getPublishedPosts());
---

<BaseLayout
  title='Tags | M1saK1 Blog'
  description='M1saK1 Blog 的标签索引。'
>
  <div class="tag-index">
    <section class="tag-index__head">
      <div class="tag-index__label">TAG INDEX</div>
      <h1>All Tags</h1>
      <span class="tag-index__count">TOTAL: {String(tags.length).padStart(2, '0')}</span>
    </section>

    <div class="tag-index__grid">
      {tags.map((tag) => (
        <a href={tagPath(tag)} class="tag-index__item">
          <span class="tag-index__hash">#</span>
          {tag}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
