---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import '../../styles/pages/tag.scss';

export async function getStaticPaths() {
    const toTime = (value: Date) => (value ? new Date(value).getTime() : 0);
    const allPosts = await getCollection('posts');
    const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts
            .filter((post) => post.data.tags.includes(tag))
            .sort((a, b) => toTime(b.data.pubDate) - toTime(a.data.pubDate));
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout
  title={`${tag} | M1saK1 Blog`}
  description={`M1saK1 Blog 中带有 ${tag} 标签的文章列表。`}
>
  <div class="tag-stream">
    <section class="tag-stream__head">
      <div class="tag-stream__label">
        <span>FILTERED BY</span>
        <span class="tag-stream__filter">#{tag}</span>
      </div>
      <span class="tag-stream__count">ENTRIES: {String(posts.length).padStart(2, '0')}</span>
    </section>

    <div class="tag-stream__list">
      {posts.map((post: any) => (
        <BlogCard
          title={post.data.title}
          subtitle={post.data.category ?? (post.data.tags?.length ? post.data.tags[0] : '')}
          image={post.data.cover}
          link={`/posts/${post.id}`}
          description={post.data.description ?? ''}
          pubDate={post.data.pubDate ? new Date(post.data.pubDate) : undefined}
          tags={post.data.tags ?? []}
        />
      ))}
    </div>
  </div>
</BaseLayout>
