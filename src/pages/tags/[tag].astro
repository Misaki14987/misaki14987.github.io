---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnitsShell from '../../components/common/UnitsShell.astro';
import {
  formatPostDate,
  getAllTags,
  getPostCards,
  getPostsByTag,
  getPublishedPosts,
} from '../../scripts/publication';

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  return getAllTags(allPosts).map((tag) => ({
    params: { tag },
    props: { posts: getPostsByTag(allPosts, tag) },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const cards = getPostCards(posts);
---

<BaseLayout
  title={`${tag} | M1saK1 Blog`}
  description={`M1saK1 Blog 中带有 ${tag} 标签的文章列表。`}
  ogImage="/images/vn-blog-hero.png"
  bodyClass="units-body"
  showNavigation={false}
>
  <UnitsShell active="subjects">
    <section class="units-panel units-panel--orange">
      <header class="units-panel__head">
        <span>{String(cards.length).padStart(2, '0')}</span>
        <h1>#{tag}</h1>
        <a href="/tags/">All tags ↗</a>
      </header>

      <div class="units-posts">
        {cards.map((blog, index) => {
          const date = blog.pubDate ? formatPostDate(blog.pubDate) : null;
          return (
            <a class={`units-post units-post--${index % 4}`} href={blog.link}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <strong>{blog.title}</strong>
              <p>{blog.description}</p>
              <small>{date?.display ?? blog.subtitle}</small>
            </a>
          );
        })}
      </div>
    </section>
  </UnitsShell>
</BaseLayout>
