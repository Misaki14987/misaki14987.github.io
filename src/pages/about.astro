---
import BaseLayout from '../layouts/BaseLayout.astro';
import FriendLink from '../components/FriendLink.astro';
import UnitsShell from '../components/common/UnitsShell.astro';

const profileStats = [
  ['base', 'Hangzhou / HDU'],
  ['practice', 'Frontend systems'],
  ['learning', 'Rust / GNOME / Math'],
  ['outside', 'Rhythm game / TCG / Idol'],
];
const interests = ['Coding', 'Rhythm Game', 'TCG', 'Idol'];
---

<BaseLayout
  title="About | M1saK1 Blog"
  description="M1saK1 的个人介绍、兴趣和联系方式。"
  ogImage="/images/vn-blog-hero.png"
  bodyClass="units-body"
  showNavigation={false}
>
  <UnitsShell active="about">
    <section class="units-panel units-panel--green">
      <header class="units-panel__head">
        <span>04</span>
        <h1>AboutMe</h1>
      </header>

      <div class="units-about">
        <div>
          <h3>M1saK1</h3>
          <p>From 杭州电子科技大学，学习 Web 开发中...</p>
        </div>
        <dl>
          {profileStats.map(([term, value]) => (
            <>
              <dt>{term}</dt>
              <dd>{value}</dd>
            </>
          ))}
        </dl>
      </div>

      <div class="units-chips">
        {interests.map((interest, index) => (
          <span><b>{String(index + 1).padStart(2, '0')}</b>{interest}</span>
        ))}
      </div>
    </section>

    <section class="units-panel units-panel--white">
      <FriendLink />
    </section>
  </UnitsShell>
</BaseLayout>
