---
import BaseLayout from '../layouts/BaseLayout.astro';
import FriendLink from '../components/FriendLink.astro';
import '../styles/pages/about.scss';

const myInfo = {
  name: 'M1saK1',
  bio: 'From 杭州电子科技大学，学习Web开发中...',
  interests: ['Coding', 'Rhythm Game', 'TCG', 'Idol'],
};
---

<BaseLayout
  title="About | M1saK1 Blog"
  description="M1saK1 的个人介绍、兴趣和联系方式。"
>
  <div class="dossier">
    <section class="dossier-intro">
      <div class="dossier-intro__label">PERSONNEL DOSSIER</div>
      <h1>{myInfo.name}</h1>
    </section>

    <section class="dossier-panel">
      <div class="dossier-panel__head">
        <span class="dossier-panel__label">BIO</span>
      </div>

      <p class="dossier-bio">{myInfo.bio}</p>

      <h3 class="dossier-heading">INTERESTS</h3>
      <div class="dossier-tags">
        {myInfo.interests.map((interest) => (
          <span>{interest}</span>
        ))}
      </div>
    </section>

    <FriendLink />
  </div>
</BaseLayout>
