---
import { Image } from 'astro:assets';
import avatar from "../assets/taffy.jpg";
import '../styles/components/self.scss';

interface Props {
  class?: string;
}

const { class: wrapperClass = "" } = Astro.props as Props;

const subjects = ['Frontend', 'Rust', 'Math', 'Daily'];
---

<section class={`identity ${wrapperClass}`}>
  <div class="identity__head">
    <div>
      <h2>M1saK1</h2>
    </div>
    <span class="identity__chapter">杭州电子科技大学</span>
  </div>

  <div class="identity__portrait-row">
    <div class="identity__avatar">
      <Image
        src={avatar}
        alt="M1saK1 avatar"
        width={112}
        height={112}
        widths={[112, 224]}
        sizes="112px"
      />
    </div>
  </div>

  <dl class="identity-fields">
    <dt>focus</dt>
    <dd>frontend systems</dd>
    <dt>learning</dt>
    <dd>rust / linux / design</dd>
    <dt>off-screen</dt>
    <dd>rhythm game / imas </dd>
  </dl>

  <div class="identity-routes" aria-label="Writing subjects">
    {subjects.map((subject, index) => (
      <span><b>{String(index + 1).padStart(2, '0')}</b>{subject}</span>
    ))}
  </div>

  <div class="identity-links">
    <a href="https://github.com/Misaki14987" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://x.com/LianiuMis" target="_blank" rel="noopener noreferrer">X</a>
    <a href="https://space.bilibili.com/M1saK1" target="_blank" rel="noopener noreferrer">Bili</a>
    <a href="/rss.xml">RSS</a>
  </div>
</section>
