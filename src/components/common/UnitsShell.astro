---
import '../../styles/components/units-shell.scss';

interface Props {
  active?: 'home' | 'articles' | 'diary' | 'works';
}

const { active = 'home' } = Astro.props;
const items = [
  { key: 'home', id: '01', zh: '最新文章', en: 'Latest', href: '/', tone: 'blue' },
  { key: 'articles', id: '02', zh: '一些分享', en: 'Articles', href: '/#articles', tone: 'yellow' },
  { key: 'diary', id: '03', zh: '胡思乱想', en: 'Diary', href: '/#diary', tone: 'orange' },
  { key: 'works', id: '04', zh: '作品集', en: 'Works', href: '/#works', tone: 'green' },
];
const socials = [
  { label: 'GH', href: 'https://github.com/Misaki14987', title: 'GitHub' },
  { label: 'Bili', href: 'https://space.bilibili.com/M1saK1', title: 'Bilibili' },
  { label: 'RSS', href: '/rss.xml', title: 'RSS Feed' },
];
---

<div class="units-shell">
  <header class="units-mobile-head">
    <a class="units-brand" href="/">
      <strong>m1sak1.</strong>
      <span>I Love Schweppes</span>
    </a>
    <a class="units-mobile-cta" href="/#about" data-i18n data-zh="关于我" data-en="About">关于我</a>
    <a class="units-menu" href="/#subjects" aria-label="打开标签索引">
      <span></span>
      <span></span>
      <span></span>
    </a>
  </header>

  <nav class="units-mobile-nav" aria-label="内容导航">
    {items.slice(1).map((item) => (
      <a href={item.href} data-i18n data-zh={item.zh} data-en={item.en}>{item.zh}</a>
    ))}
    <button class="units-theme-switch units-theme-switch--mobile" type="button" data-theme-toggle>
      <span data-theme-name>UNIT</span>
    </button>
  </nav>

  <div class="units-mobile-tools">
    <div class="units-locale" aria-label="语言切换">
      <button type="button" data-locale="zh" aria-pressed="true">中文</button>
      <button type="button" data-locale="en" aria-pressed="false">EN</button>
    </div>
    <nav class="units-socials" aria-label="社交媒体">
      {socials.map((social) => (
        <a href={social.href} title={social.title} aria-label={social.title} target={social.href.startsWith('http') ? '_blank' : undefined} rel={social.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
          {social.label}
        </a>
      ))}
    </nav>
  </div>

  <aside class="units-rail" aria-label="站点导航">
    <a class="units-brand" href="/">
      <strong>米撒奇</strong>
      <span>I Love Schweppes Without Suger</span>
    </a>

    <nav class="units-rail__nav">
      {items.map((item) => (
        <a
          class={`units-tile units-tile--${item.tone}`}
          href={item.href}
          aria-current={active === item.key ? 'page' : undefined}
        >
          <span>{item.id}</span>
          <b data-i18n data-zh={item.zh} data-en={item.en}>{item.zh}</b>
          <i aria-hidden="true">↗</i>
        </a>
      ))}
    </nav>

    <a class="units-tile units-tile--purple units-tile--cta" href="/#about">
      <b data-i18n data-zh="M1saK1 是谁!" data-en="Who is M1saK1!">M1saK1是谁！</b>
    </a>

    <button class="units-theme-switch" type="button" data-theme-toggle>
      <span>THEME</span>
      <b data-theme-name>UNIT</b>
    </button>

    <div class="units-locale" aria-label="语言切换">
      <button type="button" data-locale="zh" aria-pressed="true">中文</button>
      <button type="button" data-locale="en" aria-pressed="false">EN</button>
    </div>

    <nav class="units-socials" aria-label="社交媒体">
      {socials.map((social) => (
        <a href={social.href} title={social.title} aria-label={social.title} target={social.href.startsWith('http') ? '_blank' : undefined} rel={social.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
          {social.label}
        </a>
      ))}
    </nav>
  </aside>

  <main class="units-main">
    <slot />
  </main>
</div>

<script>
  type Theme = "units" | "plain";

  const applyLocale = (locale: "zh" | "en") => {
    document.documentElement.lang = locale === "zh" ? "zh-CN" : "en";
    localStorage.setItem("site-locale", locale);
    document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((node) => {
      node.textContent = node.dataset[locale] || node.textContent;
    });
    document.querySelectorAll<HTMLButtonElement>("[data-locale]").forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.locale === locale));
    });
  };

  const applyTheme = (theme: Theme) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("site-theme", theme);
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
      const nextTheme = theme === "units" ? "plain" : "units";
      const nextName = nextTheme === "units" ? "UNIT" : "PLAIN";
      button.setAttribute("aria-label", `切换到 ${nextName} 主题`);
      button.setAttribute("title", `切换到 ${nextName} 主题`);
      button.querySelector<HTMLElement>("[data-theme-name]")!.textContent = theme === "units" ? "UNIT" : "PLAIN";
    });
  };

  const savedTheme = (): Theme => {
    const requestedTheme = new URLSearchParams(location.search).get("theme");
    if (requestedTheme === "plain" || requestedTheme === "units") return requestedTheme;
    return localStorage.getItem("site-theme") === "plain" ? "plain" : "units";
  };

  const mountControls = () => {
    document.querySelectorAll<HTMLButtonElement>("[data-locale]").forEach((button) => {
      button.onclick = () => applyLocale(button.dataset.locale === "en" ? "en" : "zh");
    });
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((button) => {
      button.onclick = () => applyTheme(document.documentElement.dataset.theme === "plain" ? "units" : "plain");
    });

    applyLocale(localStorage.getItem("site-locale") === "en" ? "en" : "zh");
    applyTheme(savedTheme());
  };

  document.addEventListener("astro:after-swap", () => applyTheme(savedTheme()));
  document.addEventListener("astro:page-load", mountControls);
  mountControls();
</script>
