---
import '../../styles/components/card.scss';

const { title, subtitle, variant = 'solid', class: additionalClasses = '' } = Astro.props;

const variantClass = variant === 'solid' ? 'card--solid' : 'card--frosted';
---
<section class={`card ${variantClass} ${additionalClasses}`}>
  <h2 class="card__title">{title}</h2>
  {subtitle && <p class="card__subtitle">{subtitle}</p>}
  <slot />
</section>
