---
import '../../styles/components/navigation.scss';
import { isNavigationPathActive } from '../../scripts/navigation';

const currentPath = Astro.url.pathname;
const links = [
  { href: '/', index: '01', label: 'Notes' },
  { href: '/about/', index: '02', label: 'Profile' },
  { href: '/tags/', index: '03', label: 'Index' },
];

const isActive = (href: string) => isNavigationPathActive(currentPath, href);
---

<header class="site-header" transition:persist>
  <div class="header-inner">
    <a class="site-title" href="/">
      <span class="site-title__mark" aria-hidden="true">M1</span>
      <span>
        <strong>M1saK1</strong>
      </span>
    </a>

    <nav class="nav">
      {links.map((link) => (
        <a
          class:list={{ active: isActive(link.href) }}
          href={link.href}
          data-nav-link
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          <span aria-hidden="true">{link.index}</span>
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
