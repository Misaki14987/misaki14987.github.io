---
import { Image } from 'astro:assets';
import { formatPostDate, postTone, type PostTone } from '../scripts/publication';
import '../styles/components/blog-card.scss';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata | string;
  link: string;
  description: string;
  class?: string;
  pubDate?: Date;
  tags?: string[];
  entryId?: string;
  priority?: boolean;
  tone?: PostTone;
  encrypted?: boolean;
  encryptedVerify?: { salt: string; iv: string; verify: string; iterations: number } | null;
}

const {
  title,
  subtitle,
  image,
  link,
  description,
  pubDate,
  class: wrapperClass,
  tags = [],
  entryId = '',
  priority = false,
  tone: providedTone,
  encrypted = false,
  encryptedVerify = null,
}: Props = Astro.props;

const tone = providedTone ?? postTone({ title, subtitle, tags });
const formattedDate = pubDate ? formatPostDate(pubDate) : undefined;
const kind = subtitle || tags[0] || 'Diary';
const searchableText = [title, subtitle, description, ...tags]
  .filter(Boolean)
  .join(' ')
  .toLocaleLowerCase('zh-CN');
const cardClass = [
  'archive-entry',
  wrapperClass,
  !image && 'archive-entry--no-cover',
  encrypted && 'archive-entry--locked',
].filter(Boolean).join(' ');
const encryptedMeta = encrypted && encryptedVerify
  ? JSON.stringify({ slug: link.replace(/^\/posts\//, '').replace(/\/$/, ''), link, ...encryptedVerify })
  : '';
---

<article
  class={cardClass}
  data-tone={tone}
  data-search={searchableText}
  data-tags={tags.join('|').toLocaleLowerCase('zh-CN')}
  data-date={pubDate?.getTime() ?? 0}
  data-encrypted={encrypted ? 'true' : 'false'}
  data-encrypted-meta={encryptedMeta || undefined}
  data-encrypted-title={title}
>
  <div class="entry-index" aria-hidden="true">
    <span>{entryId?.replace('SCENE-', '') || '—'}</span>
    <i></i>
  </div>

  {image && (
    <a
      href={encrypted ? '#' : link}
      class="entry-cover"
      aria-label={`Read ${title}`}
      data-encrypted-link={encrypted ? 'true' : undefined}
    >
      {typeof image === 'string' ? (
        <img
          src={image}
          alt={title}
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      ) : (
        <Image
          src={image}
          alt={title}
          widths={[320, 480, 640]}
          sizes="(max-width: 1024px) calc(100vw - 84px), 300px"
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      )}
    </a>
  )}

  <div class="entry-body">
    <div class="entry-meta">
      {formattedDate && <time datetime={formattedDate.machine}>{formattedDate.display}</time>}
      {kind && <span>{kind}</span>}
      {encrypted && (
        <span class="entry-lock" aria-label="已加密" title="已加密">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4.5" y="10.5" width="15" height="10" rx="1.2" />
            <path d="M7.8 10.5V7.5a4.2 4.2 0 0 1 8.4 0v3" />
          </svg>
          加密
        </span>
      )}
    </div>

    <h3 class="entry-title">
      <a
        href={encrypted ? '#' : link}
        data-encrypted-link={encrypted ? 'true' : undefined}
      >{title}</a>
    </h3>

    {description && <p class="entry-desc">{description}</p>}

    <div class="entry-foot">
      {tags.length > 0 && (
        <div class="entry-tags">
          {tags.slice(0, 4).map((tag) => (
            <a
              href={`/?view=articles&tag=${encodeURIComponent(tag)}`}
              data-card-tag={tag}
              aria-label={`按 ${tag} 标签筛选文章`}
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
      <a
        class="entry-jump"
        href={encrypted ? '#' : link}
        data-encrypted-link={encrypted ? 'true' : undefined}
      >
        {encrypted ? '解锁' : '阅读'}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</article>
