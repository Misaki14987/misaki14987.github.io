---
import { Image } from 'astro:assets';
import { formatPostDate, postTone, type PostTone } from '../scripts/publication';
import '../styles/components/blog-card.scss';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata | string;
  link: string;
  description: string;
  class?: string;
  pubDate?: Date;
  tags?: string[];
  entryId?: string;
  priority?: boolean;
  tone?: PostTone;
}

const {
  title,
  subtitle,
  image,
  link,
  description,
  pubDate,
  class: wrapperClass,
  tags = [],
  entryId = '',
  priority = false,
  tone: providedTone,
}: Props = Astro.props;

const tone = providedTone ?? postTone({ title, subtitle, tags });
const formattedDate = pubDate ? formatPostDate(pubDate) : undefined;
const kind = subtitle || tags[0] || 'Diary';
const searchableText = [title, subtitle, description, ...tags]
  .filter(Boolean)
  .join(' ')
  .toLocaleLowerCase('zh-CN');
const cardClass = [
  'archive-entry',
  wrapperClass,
  !image && 'archive-entry--no-cover',
].filter(Boolean).join(' ');
---

<article
  class={cardClass}
  data-tone={tone}
  data-search={searchableText}
  data-tags={tags.join('|').toLocaleLowerCase('zh-CN')}
  data-date={pubDate?.getTime() ?? 0}
>
  <div class="entry-index" aria-hidden="true">
    <span>{entryId?.replace('SCENE-', '') || '—'}</span>
    <i></i>
  </div>

  {image && (
    <a href={link} class="entry-cover" aria-label={`Read ${title}`}>
      {typeof image === 'string' ? (
        <img
          src={image}
          alt={title}
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      ) : (
        <Image
          src={image}
          alt={title}
          widths={[320, 480, 640]}
          sizes="(max-width: 1024px) calc(100vw - 84px), 300px"
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      )}
    </a>
  )}

  <div class="entry-body">
    <div class="entry-meta">
      {formattedDate && <time datetime={formattedDate.machine}>{formattedDate.display}</time>}
      {kind && <span>{kind}</span>}
    </div>

    <h3 class="entry-title">
      <a href={link}>{title}</a>
    </h3>

    {description && <p class="entry-desc">{description}</p>}

    <div class="entry-foot">
      {tags.length > 0 && (
        <div class="entry-tags">
          {tags.slice(0, 4).map((tag) => <span>#{tag}</span>)}
        </div>
      )}
      <a class="entry-jump" href={link}>
        阅读
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</article>
