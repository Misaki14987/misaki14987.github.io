---
import { Image } from 'astro:assets';
import { formatPostDate } from '../scripts/publication';
import '../styles/components/blog-card.scss';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata | string;
  link: string;
  description: string;
  class?: string;
  pubDate?: Date;
  tags?: string[];
  entryId?: string;
  priority?: boolean;
}

const {
  title,
  subtitle,
  image,
  link,
  description,
  pubDate,
  class: wrapperClass,
  tags = [],
  entryId = '',
  priority = false,
}: Props = Astro.props;

const formattedDate = pubDate ? formatPostDate(pubDate) : undefined;
const kind = subtitle ? subtitle.toUpperCase().replace(/\s/g, "_") : "POST";
const cardClass = [
  'archive-entry',
  wrapperClass,
  !image && 'archive-entry--no-cover',
].filter(Boolean).join(' ');
---

<article class={cardClass}>
  {image && (
    <a href={link} class="entry-cover">
      {typeof image === 'string' ? (
        <img
          src={image}
          alt={title}
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      ) : (
        <Image
          src={image}
          alt={title}
          widths={[320, 480, 640]}
          sizes="(max-width: 1024px) calc(100vw - 84px), 300px"
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : 'auto'}
        />
      )}
    </a>
  )}

  <div class="entry-body">
    <div class="entry-meta">
      {entryId && <span class="entry-id">{entryId}</span>}
      {formattedDate && <time datetime={formattedDate.machine}>{formattedDate.display}</time>}
      <span>{kind}</span>
    </div>

    <h3 class="entry-title">
      <a href={link}>{title}</a>
    </h3>

    {description && <p class="entry-desc">{description}</p>}

    {tags.length > 0 && (
      <div class="entry-tags">
        {tags.map((tag) => <span>#{tag}</span>)}
      </div>
    )}
  </div>
</article>
