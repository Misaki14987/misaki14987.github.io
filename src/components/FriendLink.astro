---
import '../styles/components/friend-link.scss';

const friends = [
    { name: 'summ2', url: 'https://summ2.link', description: 'Vidar Team Pwn, awmc', image: 'https://nan0in27.cn/%E5%8F%8B%E9%93%BE/summ2.jpg' },
    { name: 'nan0in', url: 'https://nan0in27.cn', description: 'ORAYS Pwn, 向今日致以极夜为安，没有爱，就无法看见', image: 'https://nan0in27.cn/img/avatar_hu_f5c4bcf31b1d730.png' }
]
---

<section class="friend-section">
  <div class="friend-section__head">
    <span class="friend-section__label">CONTACT REGISTRY</span>
    <span class="friend-section__count">ENTRIES: {String(friends.length).padStart(2, '0')}</span>
  </div>

  <div class="friend-section__list">
    {friends.map((friend) => (
      <article class="friend-entry">
        {friend.image && (
          <a href={friend.url} target="_blank" rel="noopener noreferrer" class="friend-entry__avatar">
            <img
              src={friend.image}
              alt={friend.name}
              loading="lazy"
            />
          </a>
        )}

        <div class="friend-entry__body">
          <h3 class="friend-entry__name">
            <a href={friend.url} target="_blank" rel="noopener noreferrer">{friend.name}</a>
          </h3>

          <div class="friend-entry__meta">
            <span class="friend-entry__url">{friend.url}</span>
          </div>

          {friend.description && (
            <p class="friend-entry__desc">{friend.description}</p>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
