---
const friends = [
    { name: 'summ2', url: 'https://summ2.link', description: 'Vidar Team Pwn, awmc', image: 'https://nan0in27.cn/%E5%8F%8B%E9%93%BE/summ2.jpg' },
    { name: 'nan0in', url: 'https://nan0in27.cn', description: 'ORAYS Pwn, Hack for fun', image: 'https://nan0in27.cn/img/avatar_hu_85437ba0800ccf1d.png' }
]
---

<section class="friend-section">
  <h2 class="friend-section__title">友链</h2>

  <div class="friend-section__list">
    {friends.map((friend) => (
      <article class="friend-entry">
        {friend.image && (
          <a href={friend.url} target="_blank" rel="noopener noreferrer" class="friend-entry__avatar">
            <img
              src={friend.image}
              alt={friend.name}
              loading="lazy"
              decoding="async"
              width="64"
              height="64"
            />
          </a>
        )}

        <div class="friend-entry__body">
          <h3 class="friend-entry__name">
            <a href={friend.url} target="_blank" rel="noopener noreferrer">{friend.name}</a>
          </h3>

          {friend.description && (
            <p class="friend-entry__desc">{friend.description}</p>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
