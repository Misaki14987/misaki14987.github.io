---
import '../styles/components/encrypted.scss';
---

<div class='encrypted-modal' data-encrypted-modal hidden>
  <div class='encrypted-modal__backdrop' data-encrypted-backdrop></div>
  <div
    class='encrypted-modal__card'
    role='dialog'
    aria-modal='true'
    aria-label='Lock'
    data-encrypted-card
  >
    <button
      class='encrypted-modal__close'
      type='button'
      data-encrypted-close
      aria-label='关闭'
    >
      <span aria-hidden='true'>×</span>
    </button>

    <div class='encrypted-gate' data-encrypted-gate>
      <div class='encrypted-gate__lock' aria-hidden='true'>
        <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'>
          <rect x='4.5' y='10.5' width='15' height='10' rx='1.2' />
          <path d='M7.8 10.5V7.5a4.2 4.2 0 0 1 8.4 0v3' />
          <circle cx='12' cy='15.2' r='1.3' fill='currentColor' stroke='none' />
        </svg>
      </div>
      <p class='encrypted-gate__label' data-encrypted-label>这篇博客已加密</p>
      <p class='encrypted-gate__hint' data-encrypted-hint>输入密码以阅读全文</p>
      <form class='encrypted-gate__form' data-encrypted-form autocomplete='off'>
        <input
          type='password'
          name='password'
          class='encrypted-gate__input'
          placeholder='密码'
          autocomplete='off'
          data-encrypted-input
        />
        <button type='submit' class='encrypted-gate__submit'>解锁</button>
      </form>
      <p class='encrypted-gate__error' data-encrypted-error hidden>你叮不到咚鸡吗</p>
    </div>
  </div>
</div>
